  "title": "IA Prédictive & Data Platform — RetailFlow",
  "theme": "data",
  "difficulty": "hard",
  "deadline_days": 28,
  "deal_size": "1,2M€",
  "client": "RetailFlow Group",
  "context": "RetailFlow Group, enseigne de distribution avec 450 points de vente, souhaite construire une plateforme data centralisée et déployer des modèles d'IA prédictive pour optimiser ses stocks, personnaliser ses offres et anticiper la demande. L'AO porte sur la conception de la data platform (Lakehouse), l'ingestion de 30 sources de données hétérogènes, la mise en production de 3 modèles ML et l'accompagnement des équipes analytics internes.",

  "requirements": [
    {
      "id": "REQ-1",
      "section": "Architecture Data Platform",
      "description": "Proposition d'une architecture Lakehouse (ex: Databricks/Delta Lake ou AWS S3+Glue+Athena) avec gouvernance des données, data catalog, et couche de sécurité. Schéma d'architecture obligatoire.",
      "weight": 25
    },
    {
      "id": "REQ-2",
      "section": "Ingestion et intégration des données",
      "description": "Stratégie d'ingestion de 30 sources (ERP SAP, POS, CRM Salesforce, e-commerce, IoT capteurs entrepôts). Temps de latence maximum : 15 minutes pour les flux temps-réel.",
      "weight": 20
    },
    {
      "id": "REQ-3",
      "section": "Modèles IA/ML",
      "description": "Conception et mise en production de 3 modèles : prévision de la demande (LSTM/Prophet), recommandation produit (collaborative filtering), et détection d'anomalies stocks. Métriques de performance attendues définies.",
      "weight": 25
    },
    {
      "id": "REQ-4",
      "section": "Équipe et profils",
      "description": "Data Architect, Data Engineers (x2 minimum), ML Engineers (x2), Data Scientist, Project Manager. Expérience retail exigée pour au moins 2 profils.",
      "weight": 10
    },
    {
      "id": "REQ-5",
      "section": "Transfert de compétences",
      "description": "Programme de formation des équipes analytics internes (10 personnes). Certification Data Engineer validée en fin de projet. Documentation complète.",
      "weight": 10
    },
    {
      "id": "REQ-6",
      "section": "Gouvernance & qualité des données",
      "description": "Mise en place d'un Data Quality Framework avec règles de validation, lineage, et alertes. Conformité RGPD sur les données clients.",
      "weight": 10
    }
  ],

